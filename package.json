{
  "name": "opencode-local-provider",
  "version": "0.0.1",
  "type": "module",
  "description": "OpenCode plugin that adds a 'local' provider with auto-detection for Ollama, LMStudio, llama.cpp, and vLLM",
  "main": "./dist/index.js",
  "exports": {
    ".": "./src/index.ts",
    "./server": "./src/index.ts"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir=dist --target=bun --format=esm --packages=external"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.3.15",
    "@opencode-ai/sdk": "^1.3.15"
  }
}
